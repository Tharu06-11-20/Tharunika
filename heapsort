#include<iostream>
#include<cmath>
using namespace std;
int main()
{
   int n,i,j,v;
   cout<<"Enter no of  elements:"<<endl;
   cin>>n;
   if(n<0)
   {
      cout<<"Enter valid no of elements(non-negative)"<<endl;
   }
   bool heap;
   int a[n];
   if(n>0)
   {
   cout<<"Enter elements of array:"<<endl;
   for (i=1;i<=n;i++)
   {
      cin>>a[i];
   }
   }
  for(i=floor(n/2);i>=1;i--)
      {

         int k=i;
         v=a[k];
         heap=false;

         while(!heap && 2*k<=n)
          {
                j=2*k;
                if(j<n)
                {
                 if(a[j]<a[j+1])
                {
                        j=j+1;
                }
                if(v>=a[j])
               {
                 heap=true;
               }
                else
               {
                 a[k]=a[j];
                 k=j;
               }
         }
         a[k]=v;
         }

      }

int b[n];
j=0;
if(n>0){
   cout<<"After Bottom up approach:"<<endl;
   for(i=1;i<=n;i++)
   {
      b[j]=a[i];
      cout<<a[i]<<"\t";
      j++;
   }
   cout<<endl;
}
for(i=0;i<n-1;i++)
{
   for(j=i+1;j<n;j++)
   {
   if (b[i]>b[j])
   {
   int temp=b[i];
   b[i]=b[j];
   b[j]=temp;
   }
   }
}

cout<<"After sorting:"<<endl;
for(int i=0;i<n;i++)
{
   cout<<b[i]<<"\t";
}
cout<<endl;

}
