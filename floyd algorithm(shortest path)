#include <iostream>
#include <algorithm>

using namespace std;

int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;
    int D[100][100];
    if(n>0){
    cout << "Enter adjacency matrix (-1 for no path):\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            int input;
            cin >> input;

            if (i == j) {
                D[i][j] = 0;
            } else if (input == -1) {
                D[i][j] = 999999;
            } else {
                D[i][j] = input;
            }
        }
    }
    }
    else{
       cout<<"Enter a valid no of vertices(non-negative)"<<endl;
    }
    cout<<"The provided path to the graph(-1 means non-reachable"<<endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
           if(D[i][j]==999999){
              cout<<"-1";
           }
           else{

                cout << D[i][j] << " ";
            }
        }

        cout << endl;
    }
    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {

                D[i][j] = min(D[i][j], D[i][k] + D[k][j]);

            }
        }
    }
    if(n>0){
    cout << "\nShortest path matrix (-1 means unreachable):\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            if (D[i][j] >= 999999) {
                cout << "-1 ";
            } else {
                cout << D[i][j] << " ";
            }
        }
        cout << endl;
    }}

    return 0;
}
