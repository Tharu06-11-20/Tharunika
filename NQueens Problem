#include <iostream>
#include <cmath>   
using namespace std;

int board[20];   
int n, solutions = 0;
bool isSafe(int row, int col) {
    for (int i = 0; i < row; i++) {
        if (board[i] == col || abs(board[i] - col) == abs(i - row)) {
            return false;
        }
    }
    return true;
}
void solve(int row) {
    if (row == n) {
        cout << "Solution " << ++solutions << ":\n";
        
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                if (board[i] == j)
                    cout << "Q ";
                else
                    cout << "0 ";
            }
            cout << endl;
        }
        cout << endl;
        return;
    }

    for (int col = 0; col < n; col++) {
        if (isSafe(row, col)) {
            board[row] = col; 
            solve(row + 1);
        }
    }
}
int main() {
    cout << "Enter value of N: ";
    cin >> n;

    if (n <= 0) {
        cout << "Enter a positive number.\n";
        return 0;
    }

    solve(0);

    if (solutions == 0)
        cout << "No solution exists.\n";
    else
        cout << "Total solutions: " << solutions << endl;

    return 0;
}
