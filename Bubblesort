#include<iostream>
using namespace std;
int main()
{
   int n;
   cout<<"enter no of elements:"<<endl;
   cin>>n;
   int arr[n];
   cout<<"enter elements of array:"<<endl;
   for(int i=0;i<n;i++)
   {
      cin>>arr[i];
   }
   cout<<"Given array before sorting:"<<endl;
   for(int i=0;i<n;i++)
   {
      cout<<arr[i]<<"\t";
   }
   cout<<endl;
   cout<<"Bubble sorting"<<endl;
   for(int i=0;i<=n-2;i++)
   {
      bool flag=false;
      for(int j=0;j<=n-2-i;j++)
      {
         if(arr[j]>arr[j+1])
         {
            int temp=arr[j];
            arr[j]=arr[j+1];
            arr[j+1]=temp;
         }
          flag=true;
      }if(!flag)
      {
         break;
      }
   }
   cout<<"After sorting"<<endl;
   for(int i=0;i<n;i++)
   {
      cout<<arr[i]<<"\t";
   }
   cout<<endl;
}
